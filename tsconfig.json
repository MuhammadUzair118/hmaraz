{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "paths": {
      "@hamraz/types": ["./packages/types/src/index.ts"],
      "@hamraz/config": ["./packages/config/src/index.ts"],
      "@hamraz/logger": ["./packages/logger/src/index.ts"],
      "@hamraz/utils": ["./packages/utils/src/index.ts"],
      "@hamraz/database": ["./packages/database/src/index.ts"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".next",
    "coverage"
  ]
}
