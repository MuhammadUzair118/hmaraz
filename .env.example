# ── Hamraz Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values

# Supabase (Database + Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Next.js Client-side Supabase (must start with NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# PostgreSQL (for Prisma direct connection)
DATABASE_URL=postgresql://postgres:password@localhost:5432/hamraz
DIRECT_URL=postgresql://postgres:password@localhost:5432/hamraz

# Auth
JWT_SECRET=your-jwt-secret-change-in-production
CRON_SECRET=your-cron-secret-change-in-production

# Web App
NEXT_PUBLIC_API_URL=http://localhost:3000

# AI Providers
AI_DEFAULT_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Database connection pool (increase for cron jobs)
DATABASE_POOL_CONNECTIONS=10

# Logging
NODE_ENV=development
LOG_LEVEL=debug
